{
  "mcpServers": {
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "{{slack_bot_token}}",
        "SLACK_TEAM_ID": "{{slack_team_id}}"
      }
    },
    "hubspot": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-hubspot"
      ],
      "env": {
        "HUBSPOT_ACCESS_TOKEN": "{{hubspot_access_token}}"
      }
    }
  }
}
